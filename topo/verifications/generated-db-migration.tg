verification verification_generated_db_migration {
  name "Generated DB Migration Verification"
  description "Runs Topogram check, DB snapshot emission, DB migration planning, SQL migration emission, app regeneration, and generated app compile verification for the generated-owned DB migration checkpoint."
  validates [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes]
  method runtime
  scenarios [topogram_db_snapshot_migration_generate_verify]
  status active
}
