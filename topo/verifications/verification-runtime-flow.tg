verification ver_runtime_flow {
  name "Content approval runtime flow"
  description "Verifies the core content approval runtime behavior."

  validates [cap_submit_content, cap_get_submission, cap_list_submissions, cap_approve_submission, cap_request_changes]
  method runtime

  scenarios [
    submit_content_runtime,
    get_created_submission_runtime,
    list_submissions_runtime,
    approve_submission_runtime,
    request_changes_runtime
  ]

  status active
}
