verification ver_runtime_smoke {
  name "Starter runtime smoke"
  description "Verifies the generated content approval service through runtime smoke checks."

  validates [cap_submit_content, cap_get_submission, cap_list_submissions, cap_approve_submission, cap_request_changes]
  method runtime

  scenarios [
    submit_content_smoke,
    get_submission_smoke,
    list_submissions_smoke
  ]

  status active
}
