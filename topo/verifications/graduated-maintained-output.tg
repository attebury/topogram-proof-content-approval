verification verification_graduated_maintained_output {
  name "Graduated Maintained Output Verification"
  description "Runs Topogram check, generated-app compile verification, and a negative generation attempt proving maintained app output is not overwritten."
  validates [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes]
  method runtime
  scenarios [topogram_check_verify_generation_refusal]
  status active
}
