requirement req_content_approval_domain {
  name "Content Approval Domain"
  description "The proof project must replace the neutral starter greeting model with a content approval domain while keeping app output generated-owned and verifiable."
  affects [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes]
  introduces_rules []
  respects_rules []
  priority medium
  status approved
}
