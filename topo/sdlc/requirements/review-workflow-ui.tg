requirement req_review_workflow_ui {
  name "Review Workflow UI"
  description "The proof project must show reusable widget contracts, widget bindings, and behavior evidence for the content approval review workflow while generated app ownership remains active."
  affects [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes]
  introduces_rules []
  respects_rules []
  priority medium
  status approved
}
