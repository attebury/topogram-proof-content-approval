requirement req_generated_db_migration {
  name "Generated DB Migration"
  description "The generated-owned proof app must show that database contract changes produce reviewable snapshots, migration plans, SQL migration artifacts, regenerated DB lifecycle output, and a passing generated compile gate."
  affects [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes]
  introduces_rules []
  respects_rules []
  priority medium
  status approved
}
