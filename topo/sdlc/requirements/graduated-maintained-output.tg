requirement req_graduated_maintained_output {
  name "Graduated Maintained Output"
  description "The proof project must show that a generated app can graduate to maintained ownership and that Topogram refuses to overwrite maintained app output."
  affects [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes]
  introduces_rules []
  respects_rules []
  priority medium
  status approved
}
