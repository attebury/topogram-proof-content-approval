# App bundle defaults
TOPOGRAM_ENVIRONMENT_PROFILE=local_process
TOPOGRAM_DEPLOY_PROFILE=fly_io

# Local runtime defaults
DB_PORT=5432
SERVER_PORT=3000
WEB_PORT=5173
POSTGRES_DB=topogram_starter
POSTGRES_USER=${USER:-postgres}
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://${POSTGRES_USER}@localhost:5432/topogram_starter
DATABASE_ADMIN_URL=postgresql://${POSTGRES_USER}@localhost:5432/postgres
PUBLIC_TOPOGRAM_API_BASE_URL=http://localhost:3000
PUBLIC_TOPOGRAM_DEMO_USER_ID=
TOPOGRAM_DEMO_USER_ID=
PUBLIC_TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333
TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333
TOPOGRAM_DEMO_MESSAGE=hello-from-topogram
TOPOGRAM_SEED_DEMO=true

# Smoke-test defaults
TOPOGRAM_API_BASE_URL=http://localhost:3000
TOPOGRAM_WEB_BASE_URL=http://localhost:5173
