{
  "type": "runtime_check_plan",
  "name": "Content Approval Runtime Check Plan",
  "projections": {
    "api": "proj_api",
    "ui": "proj_web_surface",
    "db": "proj_db_postgres"
  },
  "topology": {
    "runtimes": [
      {
        "id": "app_api",
        "kind": "api_service",
        "projection": "proj_api",
        "generator": {
          "id": "@topogram/generator-hono-api",
          "package": "@topogram/generator-hono-api",
          "version": "1"
        }
      },
      {
        "id": "app_sveltekit",
        "kind": "web_surface",
        "projection": "proj_web_surface",
        "generator": {
          "id": "@topogram/generator-sveltekit-web",
          "package": "@topogram/generator-sveltekit-web",
          "version": "1"
        }
      },
      {
        "id": "app_postgres",
        "kind": "database",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "@topogram/generator-postgres-db",
          "package": "@topogram/generator-postgres-db",
          "version": "1"
        }
      }
    ]
  },
  "verification": {
    "methods": [
      "runtime"
    ],
    "sources": [
      {
        "id": "ver_runtime_flow",
        "name": "Content approval runtime flow",
        "method": "runtime",
        "validates": [
          "cap_submit_content",
          "cap_get_submission",
          "cap_list_submissions",
          "cap_approve_submission",
          "cap_request_changes"
        ]
      },
      {
        "id": "ver_runtime_smoke",
        "name": "Starter runtime smoke",
        "method": "runtime",
        "validates": [
          "cap_submit_content",
          "cap_get_submission",
          "cap_list_submissions",
          "cap_approve_submission",
          "cap_request_changes"
        ]
      },
      {
        "id": "verification_content_approval_domain",
        "name": "Content Approval Domain Verification",
        "method": "runtime",
        "validates": [
          "cap_list_submissions",
          "cap_get_submission",
          "cap_submit_content",
          "cap_approve_submission",
          "cap_request_changes"
        ]
      },
      {
        "id": "verification_generated_baseline",
        "name": "Generated Baseline Verification",
        "method": "runtime",
        "validates": [
          "cap_list_submissions",
          "cap_get_submission",
          "cap_submit_content",
          "cap_approve_submission",
          "cap_request_changes"
        ]
      },
      {
        "id": "verification_generated_db_migration",
        "name": "Generated DB Migration Verification",
        "method": "runtime",
        "validates": [
          "cap_list_submissions",
          "cap_get_submission",
          "cap_submit_content",
          "cap_approve_submission",
          "cap_request_changes"
        ]
      },
      {
        "id": "verification_review_workflow_ui",
        "name": "Review Workflow UI Verification",
        "method": "runtime",
        "validates": [
          "cap_list_submissions",
          "cap_get_submission",
          "cap_submit_content",
          "cap_approve_submission",
          "cap_request_changes"
        ]
      }
    ],
    "scenarios": [
      {
        "id": "submit_content_runtime",
        "label": "submit content runtime"
      },
      {
        "id": "get_created_submission_runtime",
        "label": "get created submission runtime"
      },
      {
        "id": "list_submissions_runtime",
        "label": "list submissions runtime"
      },
      {
        "id": "approve_submission_runtime",
        "label": "approve submission runtime"
      },
      {
        "id": "request_changes_runtime",
        "label": "request changes runtime"
      },
      {
        "id": "submit_content_smoke",
        "label": "submit content smoke"
      },
      {
        "id": "get_submission_smoke",
        "label": "get submission smoke"
      },
      {
        "id": "list_submissions_smoke",
        "label": "list submissions smoke"
      },
      {
        "id": "topogram_check_generate_verify",
        "label": "topogram check generate verify"
      },
      {
        "id": "topogram_db_snapshot_migration_generate_verify",
        "label": "topogram db snapshot migration generate verify"
      },
      {
        "id": "topogram_check_widget_reports_generate_verify",
        "label": "topogram check widget reports generate verify"
      }
    ]
  },
  "env": {
    "required": [
      "TOPOGRAM_API_BASE_URL",
      "TOPOGRAM_WEB_BASE_URL",
      "TOPOGRAM_DEMO_PRIMARY_ID"
    ],
    "apiBase": "TOPOGRAM_API_BASE_URL",
    "webBase": "TOPOGRAM_WEB_BASE_URL",
    "demoContainerId": "TOPOGRAM_DEMO_BODY",
    "demoPrimaryId": "TOPOGRAM_DEMO_PRIMARY_ID",
    "demoUserId": "TOPOGRAM_DEMO_USER_ID"
  },
  "report": {
    "outputPath": "state/runtime-check-report.json"
  },
  "stages": [
    {
      "id": "environment",
      "name": "Environment Readiness",
      "failFast": true,
      "checks": [
        {
          "id": "required_env",
          "kind": "env_required",
          "mandatory": true,
          "mutating": false
        },
        {
          "id": "web_home_ready",
          "kind": "web_contract",
          "path": "/",
          "expectStatus": 200,
          "expectText": "Topogram Starter",
          "mandatory": true,
          "mutating": false
        },
        {
          "id": "api_health_ready",
          "kind": "api_health",
          "path": "/health",
          "expectStatus": 200,
          "expectOk": true,
          "mandatory": true,
          "mutating": false
        },
        {
          "id": "api_ready",
          "kind": "api_ready",
          "path": "/ready",
          "expectStatus": 200,
          "expectReady": true,
          "mandatory": true,
          "mutating": false
        },
        {
          "id": "api_seed_submission_ready",
          "kind": "api_contract",
          "capabilityId": "cap_get_submission",
          "pathParams": {
            "submission_id": "$env:TOPOGRAM_DEMO_PRIMARY_ID"
          },
          "mandatory": true,
          "mutating": false
        }
      ]
    },
    {
      "id": "api",
      "name": "API Contract Checks",
      "checks": [
        {
          "id": "submit_content",
          "kind": "api_contract",
          "capabilityId": "cap_submit_content",
          "mutating": true,
          "mandatory": true
        },
        {
          "id": "get_created_submission",
          "kind": "api_contract",
          "capabilityId": "cap_get_submission",
          "mutating": false,
          "mandatory": true
        },
        {
          "id": "list_submissions",
          "kind": "api_contract",
          "capabilityId": "cap_list_submissions",
          "mutating": false,
          "mandatory": true
        },
        {
          "id": "approve_submission",
          "kind": "api_contract",
          "capabilityId": "cap_approve_submission",
          "mutating": true,
          "mandatory": true
        },
        {
          "id": "request_changes",
          "kind": "api_contract",
          "capabilityId": "cap_request_changes",
          "mutating": true,
          "mandatory": true
        },
        {
          "id": "invalid_submit_returns_4xx",
          "kind": "api_negative",
          "capabilityId": "cap_submit_content",
          "expectStatusClass": 4,
          "expectErrorCode": "cap_submit_content_invalid_request",
          "mutating": false,
          "mandatory": true
        },
        {
          "id": "get_unknown_submission_not_found",
          "kind": "api_negative",
          "capabilityId": "cap_get_submission",
          "expectStatus": 404,
          "expectErrorCode": "cap_get_submission_not_found",
          "mutating": false,
          "mandatory": true
        }
      ]
    }
  ]
}
