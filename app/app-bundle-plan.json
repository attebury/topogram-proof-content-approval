{
  "type": "app_bundle_plan",
  "name": "Content Approval App Bundle",
  "projections": {
    "api": "proj_api",
    "ui": "proj_web_surface",
    "db": "proj_db_postgres",
    "dbType": "db_contract",
    "dbEngine": "postgres"
  },
  "topology": {
    "runtimes": [
      {
        "id": "app_api",
        "kind": "api_service",
        "projection": "proj_api",
        "generator": {
          "id": "@topogram/generator-hono-api",
          "package": "@topogram/generator-hono-api",
          "version": "1"
        },
        "port": 3000,
        "uses_api": null,
        "uses_database": "app_postgres"
      },
      {
        "id": "app_sveltekit",
        "kind": "web_surface",
        "projection": "proj_web_surface",
        "generator": {
          "id": "@topogram/generator-sveltekit-web",
          "package": "@topogram/generator-sveltekit-web",
          "version": "1"
        },
        "port": 5173,
        "uses_api": "app_api",
        "uses_database": null
      },
      {
        "id": "app_postgres",
        "kind": "database",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "@topogram/generator-postgres-db",
          "package": "@topogram/generator-postgres-db",
          "version": "1"
        },
        "port": 5432,
        "uses_api": null,
        "uses_database": null
      }
    ]
  },
  "runtimeReference": {
    "localDbProjectionId": "proj_db_postgres",
    "serviceName": "content-approval-server",
    "ports": {
      "server": 3000,
      "web": 5173
    },
    "environment": {
      "name": "Content Approval Local Runtime Stack",
      "databaseName": "topogram_content_approval",
      "envExample": "PUBLIC_TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333\nTOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333\nTOPOGRAM_DEMO_BODY=\"Draft content waiting for editorial approval.\""
    },
    "compileCheck": {
      "name": "Content Approval Generated Compile Checks"
    },
    "smoke": {
      "name": "Content Approval Runtime Smoke Plan",
      "bundleTitle": "Content Approval Runtime Smoke Bundle",
      "defaultContainerEnvVar": "TOPOGRAM_DEMO_BODY",
      "webPath": "/",
      "expectText": "Topogram Starter",
      "createPath": "/submissions",
      "getPathPrefix": "/submissions/",
      "listPath": "/submissions",
      "createPayload": {
        "title": "Smoke Test Submission",
        "author_name": "Smoke Author",
        "containerField": "body"
      }
    },
    "runtimeCheck": {
      "name": "Content Approval Runtime Check Plan",
      "bundleTitle": "Content Approval Runtime Check Bundle",
      "requiredEnv": [
        "TOPOGRAM_API_BASE_URL",
        "TOPOGRAM_WEB_BASE_URL",
        "TOPOGRAM_DEMO_PRIMARY_ID"
      ],
      "demoContainerEnvVar": "TOPOGRAM_DEMO_BODY",
      "demoPrimaryEnvVar": "TOPOGRAM_DEMO_PRIMARY_ID",
      "lookupPaths": {},
      "stageNotes": [
        {
          "id": "environment",
          "summary": "required env, web readiness, API health, API readiness, and seeded content submission lookup"
        },
        {
          "id": "api",
          "summary": "core content submission create, get, list, approve, and request-changes paths"
        }
      ],
      "notes": [
        "Mutating checks create, approve, and request changes on a runtime-check content submission.",
        "Later stages are skipped if environment readiness fails.",
        "The generated server exposes both /health and /ready.",
        "Use the smoke bundle for a faster minimal confidence check.",
        "Use this runtime-check bundle for staged verification and JSON reporting."
      ],
      "verification": {
        "methods": [
          "runtime"
        ],
        "sources": [
          {
            "id": "ver_runtime_flow",
            "name": "Content approval runtime flow",
            "method": "runtime",
            "validates": [
              "cap_submit_content",
              "cap_get_submission",
              "cap_list_submissions",
              "cap_approve_submission",
              "cap_request_changes"
            ]
          },
          {
            "id": "ver_runtime_smoke",
            "name": "Starter runtime smoke",
            "method": "runtime",
            "validates": [
              "cap_submit_content",
              "cap_get_submission",
              "cap_list_submissions",
              "cap_approve_submission",
              "cap_request_changes"
            ]
          },
          {
            "id": "verification_content_approval_domain",
            "name": "Content Approval Domain Verification",
            "method": "runtime",
            "validates": [
              "cap_list_submissions",
              "cap_get_submission",
              "cap_submit_content",
              "cap_approve_submission",
              "cap_request_changes"
            ]
          },
          {
            "id": "verification_generated_baseline",
            "name": "Generated Baseline Verification",
            "method": "runtime",
            "validates": [
              "cap_list_submissions",
              "cap_get_submission",
              "cap_submit_content",
              "cap_approve_submission",
              "cap_request_changes"
            ]
          }
        ],
        "scenarios": [
          {
            "id": "submit_content_runtime",
            "label": "submit content runtime"
          },
          {
            "id": "get_created_submission_runtime",
            "label": "get created submission runtime"
          },
          {
            "id": "list_submissions_runtime",
            "label": "list submissions runtime"
          },
          {
            "id": "approve_submission_runtime",
            "label": "approve submission runtime"
          },
          {
            "id": "request_changes_runtime",
            "label": "request changes runtime"
          },
          {
            "id": "submit_content_smoke",
            "label": "submit content smoke"
          },
          {
            "id": "get_submission_smoke",
            "label": "get submission smoke"
          },
          {
            "id": "list_submissions_smoke",
            "label": "list submissions smoke"
          },
          {
            "id": "topogram_check_generate_verify",
            "label": "topogram check generate verify"
          }
        ]
      }
    },
    "appBundle": {
      "name": "Content Approval App Bundle",
      "demoContainerName": "Draft content waiting for editorial approval.",
      "demoPrimaryTitle": "Launch announcement"
    },
    "demoEnv": {
      "userId": "",
      "containerId": "Draft content waiting for editorial approval.",
      "primaryId": "33333333-3333-4333-8333-333333333333"
    }
  },
  "profiles": {
    "environment": "local_process",
    "deployment": "fly_io"
  },
  "commands": {
    "bootstrap": "./scripts/bootstrap.sh",
    "dev": "./scripts/dev.sh",
    "compile": "./scripts/compile-check.sh",
    "runtime": "./scripts/runtime.sh",
    "smoke": "./scripts/smoke.sh",
    "runtimeCheck": "./scripts/runtime-check.sh",
    "deployCheck": "./scripts/deploy-check.sh"
  },
  "layout": {
    "apps": "apps",
    "deploy": "deploy",
    "smoke": "smoke",
    "runtimeCheck": "runtime-check",
    "compile": "compile",
    "services": "apps/services",
    "web": "apps/web",
    "db": "apps/db",
    "native": "apps/native"
  }
}
