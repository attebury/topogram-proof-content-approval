generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContentSubmission {
  id String @db.Uuid @id
  title String
  body String
  status String
  author_name String
  created_at DateTime @db.Timestamptz(3)
  submitted_at DateTime @db.Timestamptz(3)
  reviewed_at DateTime? @db.Timestamptz(3)
  reviewer_note String?
  @@index([status])
  @@index([submitted_at])
  @@map("content_submissions")
}
