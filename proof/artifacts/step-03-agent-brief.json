{
  "edit_boundaries": {
    "output_boundaries": [
      {
        "ownership": "generated",
        "path": "./app",
        "rule": "Do not edit ./app/ directly unless changing output ownership to maintained. Regenerate it from the Topogram."
      }
    ],
    "rule": "Edit Topogram and policy files first. Avoid generated-owned output paths unless converting them to maintained ownership.",
    "safe_paths": [
      "topo/**",
      "topogram.project.json",
      "topogram.sdlc-policy.json",
      "topogram.template-policy.json",
      "topogram.generator-policy.json",
      "implementation/** after review and trust status"
    ]
  },
  "extract": null,
  "file_organization": {
    "large": [
      "topo/domains/<domain>",
      "topo/shared",
      "topo/domains/<domain>/widgets",
      "topo/domains/<domain>/projections"
    ],
    "parserRule": "Folder layout is for humans and agents; Topogram flattens statements into one graph.",
    "sdlc": [
      "topo/sdlc/pitches",
      "topo/sdlc/requirements",
      "topo/sdlc/acceptance_criteria",
      "topo/sdlc/tasks",
      "topo/sdlc/plans",
      "topo/sdlc/bugs",
      "topo/sdlc/decisions"
    ],
    "small": [
      "topo/actors",
      "topo/entities",
      "topo/shapes",
      "topo/capabilities",
      "topo/widgets",
      "topo/projections",
      "topo/verifications"
    ]
  },
  "first_commands": [
    {
      "command": "npm run agent:brief",
      "phase": "first-run",
      "reason": "Machine-readable current onboarding guidance."
    },
    {
      "command": "npm run doctor",
      "phase": "first-run",
      "reason": "Check local CLI, package, and catalog setup."
    },
    {
      "command": "npm run source:status",
      "phase": "first-run",
      "reason": "See whether template-derived files diverged locally."
    },
    {
      "command": "npm run template:explain",
      "phase": "first-run",
      "reason": "Understand whether the project is template-attached or detached."
    },
    {
      "command": "npm run generator:policy:check",
      "phase": "first-run",
      "reason": "Validate package-backed generator policy before generation."
    },
    {
      "command": "topogram sdlc policy explain --json",
      "phase": "sdlc",
      "reason": "Read current SDLC enforcement mode and protected paths."
    },
    {
      "command": "topogram query sdlc-available ./topo --json",
      "phase": "sdlc",
      "reason": "Find unclaimed tasks, unresolved bugs, and approved requirements needing a task."
    },
    {
      "command": "topogram sdlc start <task-id> --actor actor_coding_agent --json",
      "phase": "sdlc",
      "reason": "Read blockers, rules, decisions, proof gaps, and verification guidance before implementation."
    },
    {
      "command": "topogram sdlc gate . --require-adopted --json",
      "phase": "sdlc",
      "reason": "Verify protected work has SDLC linkage before PR/CI."
    },
    {
      "command": "topogram sdlc explain <task-or-bug-id> --json",
      "phase": "sdlc",
      "reason": "Start SDLC-backed implementation from the current task or bug."
    },
    {
      "command": "npm run trust:status",
      "phase": "trust",
      "reason": "Check executable implementation trust before generation."
    },
    {
      "command": "npm run check",
      "phase": "first-run",
      "reason": "Validate Topogram, project config, topology, ownership, trust, and generator policy."
    },
    {
      "command": "npm run query:list",
      "phase": "first-run",
      "reason": "Discover focused agent packets."
    },
    {
      "command": "npm run query:show -- widget-behavior",
      "phase": "focused-context",
      "reason": "Read a focused UI/widget packet before UI work."
    },
    {
      "command": "npm run generate",
      "phase": "write",
      "reason": "Write generated-owned runtime/app outputs after validation."
    },
    {
      "command": "npm run verify",
      "phase": "verify",
      "reason": "Run generated output verification."
    }
  ],
  "generator_policy": {
    "diagnostics": {
      "errors": 0,
      "items": [],
      "warnings": 0
    },
    "exists": true,
    "packageBackedGenerators": 3,
    "path": "topogram.generator-policy.json"
  },
  "project": {
    "packageJson": "<repo>/package.json",
    "projectConfigPath": "<repo>/topogram.project.json",
    "root": "<repo>",
    "topogram": "<repo>/topo"
  },
  "read_order": [
    {
      "exists": true,
      "path": "AGENTS.md",
      "reason": "Human-readable first-run guidance generated with this project.",
      "required": false
    },
    {
      "exists": true,
      "path": "README.md",
      "reason": "Project workflow and template provenance summary.",
      "required": true
    },
    {
      "exists": true,
      "path": "topogram.project.json",
      "reason": "Topology, outputs, template metadata, generator bindings, and implementation provider settings.",
      "required": true
    },
    {
      "exists": true,
      "path": "topogram.sdlc-policy.json",
      "reason": "SDLC adoption, enforcement mode, protected paths, required item kinds, and exemption policy.",
      "required": false
    },
    {
      "exists": true,
      "path": "topogram.template-policy.json",
      "reason": "Template trust/update policy for attached templates.",
      "required": false
    },
    {
      "exists": true,
      "path": "topogram.generator-policy.json",
      "reason": "Package-backed generator policy and allowed scopes.",
      "required": false
    },
    {
      "exists": true,
      "path": ".topogram-template-trust.json",
      "reason": "Executable implementation trust record, if the template copied implementation code.",
      "required": true
    },
    {
      "exists": false,
      "path": ".topogram-extract.json",
      "reason": "Brownfield extraction provenance and source evidence, if this came from extract.",
      "required": false
    },
    {
      "exists": true,
      "path": "topo/",
      "reason": "Canonical Topogram graph source. Use focused query packets for implementation work.",
      "required": true
    }
  ],
  "sdlc_policy": {
    "allowExemptions": true,
    "diagnostics": [],
    "exists": true,
    "gateCommand": "topogram sdlc gate . --require-adopted",
    "mode": "enforced",
    "path": "topogram.sdlc-policy.json",
    "protectedPaths": [
      "app/**",
      "docs/**",
      "proof/**",
      "scripts/**",
      ".github/**",
      "topo/**",
      "AGENTS.md",
      "CONTRIBUTING.md",
      "README.md",
      "package.json"
    ],
    "requiredItemKinds": [
      "task",
      "bug",
      "requirement",
      "pitch"
    ],
    "status": "adopted"
  },
  "template": {
    "id": "@topogram/starter-web-api-db",
    "includesExecutableImplementation": true,
    "requested": "@topogram/starter-web-api-db@0.1.14",
    "source": "package",
    "sourceSpec": "@topogram/starter-web-api-db@0.1.14",
    "version": "0.1.14"
  },
  "topology": {
    "outputs": [
      {
        "ownership": "generated",
        "path": "./app",
        "rule": "Do not edit ./app/ directly unless changing output ownership to maintained. Regenerate it from the Topogram."
      }
    ],
    "runtimes": [
      {
        "generator": "@topogram/generator-hono-api",
        "id": "app_api",
        "kind": "api_service",
        "migration": null,
        "projection": "proj_api",
        "uses_api": null,
        "uses_database": "app_postgres"
      },
      {
        "generator": "@topogram/generator-sveltekit-web",
        "id": "app_sveltekit",
        "kind": "web_surface",
        "migration": null,
        "projection": "proj_web_surface",
        "uses_api": "app_api",
        "uses_database": null
      },
      {
        "generator": "@topogram/generator-postgres-db",
        "id": "app_postgres",
        "kind": "database",
        "migration": null,
        "projection": "proj_db_postgres",
        "uses_api": null,
        "uses_database": null
      }
    ]
  },
  "trust": {
    "content": {
      "added": [],
      "changed": [],
      "currentDigest": "6b7295ce0f27bce8e0338fe1bc7984c890382caaf7854c78fcdb4a295367d976",
      "removed": [],
      "trustedDigest": "6b7295ce0f27bce8e0338fe1bc7984c890382caaf7854c78fcdb4a295367d976"
    },
    "implementation": {
      "export": "WEB_API_DB_IMPLEMENTATION",
      "id": "web-api-db-template",
      "module": "./implementation/index.js"
    },
    "issues": [],
    "ok": true,
    "path": ".topogram-template-trust.json",
    "requiresTrust": true
  },
  "type": "agent_brief",
  "version": "1",
  "warnings": [
    "implementation/ exists. Review executable implementation code before generation and before refreshing trust.",
    "SDLC is enforced. Protected changes need a valid SDLC item, a topo/sdlc/*.tg record update, or an explicit allowed exemption.",
    "Generated-owned outputs are replaceable by Topogram; do not make lasting edits under generated output paths."
  ],
  "workflows": [
    {
      "commands": [
        "topogram query sdlc-available ./topo --json",
        "topogram sdlc start <task-id> --actor <actor> --json",
        "topogram sdlc explain <task-or-bug-id> --json",
        "topogram query slice ./topo --task <task-id> --json",
        "topogram query sdlc-proof-gaps ./topo --task <task-id> --json",
        "topogram sdlc plan explain <plan-id> --json",
        "topogram sdlc plan step complete <plan-id> <step-id> --actor <actor> --write"
      ],
      "id": "sdlc-task-plan",
      "rule": "Start from an SDLC task packet before implementation. Plans are optional; edit plan text directly, but use CLI for status, history, step progress, and archive state.",
      "title": "SDLC task and plan loop"
    },
    {
      "commands": [
        "npm run agent:brief",
        "npm run check",
        "npm run generate",
        "npm run verify"
      ],
      "id": "greenfield-generated",
      "rule": "Edit the Topogram first, then regenerate generated-owned outputs.",
      "title": "Generated project loop"
    },
    {
      "commands": [
        "topogram query list --json",
        "topogram query show widget-behavior",
        "topogram widget check --json",
        "topogram widget behavior --json",
        "topogram emit ui-widget-contract --json"
      ],
      "id": "widget-first-ui",
      "rule": "Use focused widget and surface packets before editing UI code.",
      "title": "Widget-first UI loop"
    },
    {
      "commands": [
        "npm run source:status",
        "npm run template:explain",
        "npm run template:update:recommend",
        "npm run template:update:check"
      ],
      "id": "template-update",
      "rule": "Local Topogram files are project-owned after edits; review update plans before applying template changes.",
      "title": "Template update loop"
    },
    {
      "commands": [
        "npm run trust:status",
        "npm run trust:diff",
        "npm run template:policy:explain",
        "topogram trust template"
      ],
      "id": "executable-template",
      "rule": "Review implementation code before refreshing trust. The brief does not execute implementation providers.",
      "title": "Executable template review loop"
    }
  ]
}
